<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>HOME_DIR_PLACEHOLDER</string>
		<key>PATH</key>
		<string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
		<key>VAULT_DIR</key>
		<string>HOME_DIR_PLACEHOLDER/VaultSandbox</string>
	</dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>com.vault.telegram-bot</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/python3</string>
		<string>HOME_DIR_PLACEHOLDER/VaultSandbox/Meta/scripts/vault-bot.py</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/tmp/vault-telegram-bot.log</string>
	<key>StandardOutPath</key>
	<string>/tmp/vault-telegram-bot.log</string>
	<key>WorkingDirectory</key>
	<string>/tmp</string>
</dict>
</plist>
